% Gemini theme
% https://github.com/anishathalye/gemini

% ====================
% Definitions
% ====================

\definecolor{darkdartmouthgreen}{HTML}{27503F}
\definecolor{dartmouthgreen}{HTML}{00693E}
\definecolor{lightdartmouthgreen}{HTML}{CCE1D8}
\definecolor{darkthayerblue}{HTML}{2F3d41}
\definecolor{thayerblue}{HTML}{143743}
\definecolor{lightthayerblue}{HTML}{9CAAAF}

\colorlet{lightlightdartmouthgreen}{lightdartmouthgreen!20!white}
\colorlet{lightlightthayerblue}{lightthayerblue!10!white}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=thayerblue}

% Headline
\setbeamercolor{headline}{fg=black,bg=white}
\setbeamercolor{headline rule}{bg=lightthayerblue}

% Block
\setbeamercolor{block title}{fg=thayerblue,bg=white}
\setbeamercolor{block separator}{bg=darkdartmouthgreen}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block alerted title}{fg=thayerblue,bg=lightlightthayerblue}
\setbeamercolor{block alerted separator}{bg=darkdartmouthgreen}
\setbeamercolor{block alerted body}{fg=black,bg=lightlightthayerblue}

% Example Block
\setbeamercolor{block example title}{fg=thayerblue,bg=lightlightdartmouthgreen}
\setbeamercolor{block example separator}{bg=darkdartmouthgreen}
\setbeamercolor{block example body}{fg=black,bg=lightlightdartmouthgreen}

% Heading
\setbeamercolor{heading}{fg=black}

% Itemize
\setbeamercolor{item}{fg=thayerblue}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
\setbeamertemplate{bibliography entry article}{}
\setbeamertemplate{bibliography entry title}{}
\setbeamertemplate{bibliography entry location}{}
\setbeamertemplate{bibliography entry note}{}
