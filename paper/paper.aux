\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Qualitative reconstructions on the $16{\times }16$ scene. Top: ground-truth scene at each measurement rate. Middle: sequential pipeline (FISTA-then-correct). Bottom: proposed. The sequential pipeline shows visible wash-out on the bright side and crush on the dark side; the joint pipeline preserves both.}}{9}{figure.5}\protected@file@percent }
\newlabel{fig:joint-qual}{{5}{9}{Qualitative reconstructions on the $16{\times }16$ scene. Top: ground-truth scene at each measurement rate. Middle: sequential pipeline (FISTA-then-correct). Bottom: proposed. The sequential pipeline shows visible wash-out on the bright side and crush on the dark side; the joint pipeline preserves both}{figure.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Per-scene results at $\delta {=}0.4$, SNR${=}25$~dB, $8\times $ illumination gradient. $\log _{10}\kappa (\boldsymbol  {B}^\top \boldsymbol  {B})$ is measured after the first c-step of the joint pipeline. Note that \emph  {moon}, the worst-performing scene for the joint pipeline, has the \emph  {lowest} $\log _{10}\kappa $---falsifying the $\kappa $-gate hypothesis.}}{9}{table.6}\protected@file@percent }
\newlabel{tab:gate}{{6}{9}{Per-scene results at $\delta {=}0.4$, SNR${=}25$~dB, $8\times $ illumination gradient. $\log _{10}\kappa (\boldsymbol {B}^\top \boldsymbol {B})$ is measured after the first c-step of the joint pipeline. Note that \emph {moon}, the worst-performing scene for the joint pipeline, has the \emph {lowest} $\log _{10}\kappa $---falsifying the $\kappa $-gate hypothesis}{table.6}{}}
