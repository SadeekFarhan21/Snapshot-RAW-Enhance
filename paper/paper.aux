\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Reconstruction PSNR vs measurement SNR at $\delta {=}0.4$, mean $\pm $ std across the $5$-scene test set. FISTA dominates throughout; ADMM with fixed $\rho {=}1.0$ degrades at very low noise; all solvers plateau at $\sim 17$~dB above SNR$=20$~dB, indicating that basis mismatch (not noise) is the residual bottleneck.}}{10}{figure.6}\protected@file@percent }
\newlabel{fig:noise}{{6}{10}{Reconstruction PSNR vs measurement SNR at $\delta {=}0.4$, mean $\pm $ std across the $5$-scene test set. FISTA dominates throughout; ADMM with fixed $\rho {=}1.0$ degrades at very low noise; all solvers plateau at $\sim 17$~dB above SNR$=20$~dB, indicating that basis mismatch (not noise) is the residual bottleneck}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Left: mean test-set PSNR as a function of the gate threshold $\tau $ on $\log _{10}\kappa (\boldsymbol  {B}^\top \boldsymbol  {B})$ (gated = joint if $\log _{10}\kappa < \tau $ else sequential). The best gate $\tau ^\star {=}1.37$ recovers essentially zero advantage over sequential-only because the worst scene (\emph  {moon}, far left in the right panel) sits below \emph  {every} reasonable $\tau $. Right: per-scene joint-minus-sequential gain plotted against $\log _{10}\kappa $. The expected monotone relationship is absent.}}{10}{figure.7}\protected@file@percent }
\newlabel{fig:gate}{{7}{10}{Left: mean test-set PSNR as a function of the gate threshold $\tau $ on $\log _{10}\kappa (\boldsymbol {B}^\top \boldsymbol {B})$ (gated = joint if $\log _{10}\kappa < \tau $ else sequential). The best gate $\tau ^\star {=}1.37$ recovers essentially zero advantage over sequential-only because the worst scene (\emph {moon}, far left in the right panel) sits below \emph {every} reasonable $\tau $. Right: per-scene joint-minus-sequential gain plotted against $\log _{10}\kappa $. The expected monotone relationship is absent}{figure.7}{}}
